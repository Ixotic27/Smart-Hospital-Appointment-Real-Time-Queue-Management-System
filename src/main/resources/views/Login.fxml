<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.hospital.controllers.LoginController" stylesheets="@../styles/style.css" styleClass="main-container">
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0"/>
    </padding>

    <Label text="Smart Hospital" styleClass="title-label"/>
    <Label text="Sign in to your account" styleClass="subtitle-label"/>

    <VBox spacing="10.0" maxWidth="350">
        <Label text="Username" styleClass="field-label"/>
        <TextField fx:id="usernameField" promptText="Enter your username" styleClass="input-field"/>
        
        <Label text="Password" styleClass="field-label"/>
        <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="input-field"/>
        
        <Label text="" /> <!-- spacer -->
        <Button text="Login" onAction="#handleLogin" styleClass="login-button" maxWidth="350"/>
    </VBox>
    
    <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>
</VBox>
