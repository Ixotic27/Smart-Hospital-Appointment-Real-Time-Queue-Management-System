<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../styles/style.css" styleClass="main-container"
            fx:controller="com.hospital.controllers.DoctorController">

    <!-- Sidebar -->
    <left>
        <VBox styleClass="sidebar" prefWidth="250.0">
            <Label text="Smart Hospital" styleClass="sidebar-title"/>
            
            <Button text="My Schedule" onAction="#showSchedule" styleClass="sidebar-btn" prefWidth="250.0" alignment="BASELINE_LEFT"/>
            <Button text="Patients List" onAction="#showPatients" styleClass="sidebar-btn" prefWidth="250.0" alignment="BASELINE_LEFT"/>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox fx:id="contentArea" spacing="20.0">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
            </padding>
            
            <!-- Header -->
            <Label fx:id="headerLabel" text="Doctor Dashboard" styleClass="title-label"/>
            <Label fx:id="subHeaderLabel" text="View and manage your daily appointments." styleClass="subtitle-label"/>

            <!-- Data Card -->
            <VBox fx:id="cardArea" styleClass="card" VBox.vgrow="ALWAYS" spacing="15.0">
                <!-- Content will be injected dynamically -->
            </VBox>
        </VBox>
    </center>

</BorderPane>